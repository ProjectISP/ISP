#!/bin/sh
echo "The default for FCOMP assumes you are using gfortran"
echo "Edit this file if you are using a different compiler"
export FCMP="gfortran -fbackslash"
status=$?
cd ../lib
rm -rf *
cd ../bin
rm -f dsretc fm2focmec focmec_prep focmec focplt freesurf hypo2foc radiat ratio_prep ratplt sgftops sgfswap symdemo ttimes vwbeetle
cd ../fmsub
make
status=$?
if [ $status -ne 0 ]; then exit; fi 

cd ../iaspei-tau/src
make

status=$?
if [ $status -ne 0 ]; then exit; fi  
mv libiasp.a ../../lib
rm -f ../../bin/ttimes
mv ../bin/ttimes ../../bin
cd ../build-tables
sh build-tables_sh
status=$?
if [ $status -ne 0 ]; then exit; fi
mv *.hed *.tbl ../../lib
rm -R stuff iasp91.term ak135.term nocrust.term
cd ../src
make clean
cd ../../src
make  

